<Window x:Class="Kaxut_demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kahoot Builder" Height="480" Width="640">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Question label -->
            <RowDefinition Height="Auto"/>  <!-- Question input -->
            <RowDefinition Height="12"/>    <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Answers label -->
            <RowDefinition Height="Auto"/>  <!-- Answer 1 -->
            <RowDefinition Height="Auto"/>  <!-- Answer 2 -->
            <RowDefinition Height="Auto"/>  <!-- Answer 3 -->
            <RowDefinition Height="Auto"/>  <!-- Answer 4 -->
            <RowDefinition Height="12"/>    <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
            <RowDefinition Height="*"/>     <!-- Questions list -->
        </Grid.RowDefinitions>

        <!-- Question -->
        <TextBlock Grid.Row="0" Text="Question" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="txtQuestion" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />

        <!-- Answers -->
        <TextBlock Grid.Row="3" Text="Answers (select the correct one)" FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- Answer 0 -->
        <Grid Grid.Row="4" Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="rbCorrect0" GroupName="AnswersGroup" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Answer 1:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="2" x:Name="txtAnswer0" Margin="72,0,0,0"/>
        </Grid>

        <!-- Answer 1 -->
        <Grid Grid.Row="5" Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="rbCorrect1" GroupName="AnswersGroup" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Answer 2:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="2" x:Name="txtAnswer1" Margin="72,0,0,0"/>
        </Grid>

        <!-- Answer 2 -->
        <Grid Grid.Row="6" Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="rbCorrect2" GroupName="AnswersGroup" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Answer 3:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="2" x:Name="txtAnswer2" Margin="72,0,0,0"/>
        </Grid>

        <!-- Answer 3 -->
        <Grid Grid.Row="7" Margin="0,2,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="rbCorrect3" GroupName="AnswersGroup" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Answer 4:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="2" x:Name="txtAnswer3" Margin="72,0,0,0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" >
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button x:Name="btnAddQuestion" Content="Add Question" Width="120" Margin="0,0,8,0" Click="btnAddQuestion_Click"/>
            <Button x:Name="btnStart" Content="Start" Width="100" Click="btnStart_Click"/>
        </StackPanel>

        <!-- Список добавленных вопросов -->
        <Border Grid.Row="10" Margin="0,12,0,0" BorderBrush="#FFD0D0D0" BorderThickness="1" Padding="8" CornerRadius="4">
            <DockPanel>
                <TextBlock Text="Added questions:" FontWeight="Bold" Margin="0,0,0,6" DockPanel.Dock="Top"/>
                <ListBox x:Name="lstQuestions"
                         ItemsSource="{Binding Questions}"
                         DisplayMemberPath="Text"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
